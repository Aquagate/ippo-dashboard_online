{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synergy.schema.json",
  "type": "object",
  "required": [
    "synergy_map_id",
    "edges",
    "rules"
  ],
  "properties": {
    "synergy_map_id": {
      "type": "string"
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from_branch",
          "to_branch",
          "type",
          "strength"
        ],
        "properties": {
          "from_branch": {
            "type": "string"
          },
          "to_branch": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "primer",
              "fuel",
              "shield"
            ]
          },
          "strength": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          },
          "conditions": {
            "type": "object",
            "additionalProperties": true
          },
          "why": {
            "type": "string"
          },
          "suggestion": {
            "type": "object",
            "properties": {
              "after_node": {
                "type": "string"
              },
              "duration_min": {
                "type": "integer",
                "minimum": 1,
                "maximum": 25
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "rules": {
      "type": "object",
      "required": [
        "max_edges_per_branch",
        "max_suggestions_per_day"
      ],
      "properties": {
        "max_edges_per_branch": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "max_suggestions_per_day": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}