{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bridge_council_response.schema.json",
  "type": "object",
  "required": [
    "packet_type",
    "recommendations",
    "autopick"
  ],
  "properties": {
    "packet_type": {
      "const": "council_response"
    },
    "mode": {
      "type": "string"
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rank",
          "card_id",
          "why",
          "close_template"
        ],
        "properties": {
          "rank": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C"
            ]
          },
          "card_id": {
            "type": "string"
          },
          "why": {
            "type": "string"
          },
          "close_template": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "minItems": 1,
      "maxItems": 3
    },
    "autopick": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C"
      ]
    }
  },
  "additionalProperties": true
}