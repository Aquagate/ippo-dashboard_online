{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bridge_foundry_request.schema.json",
  "type": "object",
  "required": [
    "packet_type",
    "range",
    "events",
    "limits",
    "thresholds"
  ],
  "properties": {
    "packet_type": {
      "const": "foundry_request"
    },
    "range": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      }
    },
    "ledger_digest": {
      "type": "object",
      "additionalProperties": true
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "minItems": 0
    },
    "armory_cards": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "minItems": 0
    },
    "limits": {
      "type": "object",
      "required": [
        "forge_new_cards",
        "upgrades",
        "retires"
      ],
      "properties": {
        "forge_new_cards": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "upgrades": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "retires": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        }
      }
    },
    "thresholds": {
      "type": "object",
      "required": [
        "efficiency_min",
        "repeat_min"
      ],
      "properties": {
        "efficiency_min": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 3.0
        },
        "repeat_min": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      }
    }
  },
  "additionalProperties": true
}